generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model admin {
  id                Int       @id @default(autoincrement())
  nama              String
  email             String    @unique(map: "Admin_email_key")
  password          String
  createdAt         DateTime  @default(now())
  resetToken        String?
  resetTokenExpires DateTime?
}

model kendaraan {
  id        Int      @id @default(autoincrement())
  nama      String
  slug      String   @unique(map: "Kendaraan_slug_key")
  harga     Int
  tipe      String
  deskripsi String   @db.Text
  gambar    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fitur     String   @db.Text
  warna     String   @db.Text
}
